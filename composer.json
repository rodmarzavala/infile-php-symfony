{
    "name": "rodmarzavala/infile-php-symfony",
    "description": "Symfony adapter for infile-php — Guatemala FEL SDK",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "rodmarzavala/infile-php-core": "*",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/messenger": "^6.4|^7.0",
        "symfony/event-dispatcher": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "InfilePhp\\Symfony\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
